NODE_ENV=환경 // 'development', 'production', 'test'
PORT=포트
# ex postgresql://user:password@localhost:5432/database_name
DATABASE_URL=""
# ex: http://localhost:3000 ,https://your-frontend-domain.com [CANME과 A레코드를 둘다 넣어주세요]
# MIGRATION_DATABASE_URL=""
FRONT_URL=""
# 무통장 입금 계좌 정보
BANK_TRANSFER_ACCOUNT_BANK="REPLACE_ME_BANK_NAME"
BANK_TRANSFER_ACCOUNT_NUMBER="REPLACE_ME_ACCOUNT_NUMBER"
BANK_TRANSFER_ACCOUNT_HOLDER="REPLACE_ME_ACCOUNT_HOLDER"
# ex: .ssambee.com 
AUTH_COOKIE_DOMAIN=
# 아래 명령어로 랜덤 시크릿 생성: openssl rand --base64 32
BETTER_AUTH_SECRET=""
# Better Auth 서비스의 URL (예시: http://localhost:포트번호 또는 배포된 서비스 URL)_
BETTER_AUTH_URL=""
# Sentry DSN (공백으로 두면 sentry 미사용)
SENTRY_DSN=""

# AWS S3 Configuration (필수 사항)
AWS_ACCESS_KEY_ID="" # 보안 자격 증명 > 액세스 키 만들기
AWS_SECRET_ACCESS_KEY=""
# AWS REGION은 기본값이 아시아(서울) - ap-northeast-2
# AWS_REGION="ap-northeast-2"
AWS_S3_BUCKET_DOCUMENTS=""
AWS_S3_BUCKET_REPORTS=""
# CloudFront Configuration (선택 사항)  cloudfront > 설명과 이름 확인후 해당 아이디 클랙 > 해당 아이디에 도메인을 복사해서 여기다 붙여넣는다(documents,reports 각각 따로되어있음)
AWS_CLOUDFRONT_URL_DOCUMENTS="" # CloudFront 배포 도메인 이름 (예: d123.cloudfront.net)
AWS_CLOUDFRONT_URL_REPORTS="" 
AWS_CLOUDFRONT_KEY_PAIR_ID="" # CloudFront 키페어 ID (SIGNED URL용)
# AWS_CLOUDFRONT_PRIVATE_KEY="" # CloudFront 프라이빗 키 (SIGNED URL용) 없을시 ssm 파라마터 스토어 에서 가져오니 상관없음

# Email (SMTP - nodemailer)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
# SMTP_SECURE=false

# Redis (Upstash)
# (선택사항) REDIS 에러 알림 훅
# REDIS_URL=""
# 람다 알람 시스템 (관제)
# ALARM_LAMBDA_URL="" # Deprecated: Sentry handles alerts now
# DISCORD_WEBHOOK_URL = ""
# 비동기 로깅 시스템 (AWS Lambda -> Turso DB)
# LOG_LAMBDA_URL=""
# LOG_LAMBDA_API_KEY=""
# MONITOR_LAMBDA_URL="" # Deprecated: Datadog handles infra metrics
# INTERNAL_INGEST_SECRET=""

# Datadog Agent (Free Tier - infrastructure monitoring)
# DATADOG_API_KEY=
# DD_SITE=datadoghq.com

# Scheduler
# SCHEDULER_ENABLED=true
# SCHEDULER_POLL_INTERVAL_SECONDS=15
# SCHEDULER_JOB_FILTER=
# BILLING_RECONCILE_CRON="5 0 * * *"
# BILLING_RECONCILE_TIMEZONE="Asia/Seoul"

# 카카오 나에게 보내기 (개발용)
# developers.kakao.com > 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_REST_API_KEY=""
# 카카오 로그인 > Redirect URI (카카오 콘솔에 등록한 값과 일치해야 함)
KAKAO_REDIRECT_URI="http://localhost:포트/api/kakao/callback"
KAKAO_CLIENT_SECRET=
