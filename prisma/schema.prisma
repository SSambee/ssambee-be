// --------------------------------------------------------
// 6. CLINIC (클리닉/재시험 관리)
// --------------------------------------------------------

model Clinic {
  id        String @id @default(cuid(2))
  lectureId String @map("lecture_id")
  examId    String @map("exam_id")

  // 기존 Clinic 필드
  title     String
  deadline  DateTime?

  // 기존 ClinicTarget 필드 통합
  lectureEnrollmentId String  @map("lecture_enrollment_id")
  status              String  @default("PENDING") // PENDING, SENT, COMPLETED
  memo                String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  // 관계 설정
  lecture           Lecture           @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  exam              Exam              @relation(fields: [lectureId, examId], references: [lectureId, id], onDelete: Cascade)
  lectureEnrollment LectureEnrollment @relation(fields: [lectureEnrollmentId], references: [id], onDelete: Cascade)

  instructorId String?     @map("instructor_id")
  instructor   Instructor? @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  // 인덱스 및 제약 조건
  // 한 수강생이 동일한 시험에 대해 중복 클리닉을 받지 않도록 유니크 설정 (필요시)
  @@unique([lectureEnrollmentId, examId])
  @@index([examId])
  @@index([lectureEnrollmentId])
  @@index([status])
  @@map("clinics")
}

// --------------------------------------------------------
// 7. OPERATION SUPPORT (운영 지원)
// --------------------------------------------------------

model ScheduleCategory {
  id           String   @id @default(cuid(2))
  instructorId String   @map("instructor_id")

  name String
  color String

  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  schedules    Schedule[]

  @@unique([instructorId, name])
  @@unique([instructorId, color])
  @@index([instructorId])
  @@map("schedule_categories")
}

model Schedule {
  id           String   @id @default(cuid(2))
  instructorId String   @map("instructor_id")

  authorName String @map("author_name")
  authorRole String @map("author_role")

  title        String
  memo         String? @db.Text
  startTime    DateTime @map("start_time")
  endTime      DateTime @map("end_time")

  categoryId   String?   @map("category_id")
  category     ScheduleCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId, startTime])
  @@map("schedules")
}



model Material {
  id           String  @id @default(cuid(2))
  instructorId String  @map("instructor_id")
  lectureId    String? @map("lecture_id")

  authorName String @map("author_name")
  authorRole String @map("author_role")

  title   String
  fileUrl String @map("file_url")
  type    String @default("ETC")

  // New fields
  description         String? @db.Text // 소개/세부 내용
  subject             String? // 과목
  externalDownloadUrl String? @map("external_download_url") // 외부 다운로드 링크

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  lecture    Lecture?   @relation(fields: [lectureId], references: [id], onDelete: SetNull)
  instructor Instructor @relation("MaterialOwner", fields: [instructorId], references: [id], onDelete: Cascade)

  instructorPostAttachments InstructorPostAttachment[]
  commentAttachments        CommentAttachment[]
  orderAttachments          OrderAttachment[]

  @@index([instructorId])
  @@index([lectureId])
  @@index([deletedAt])
  @@map("materials")
}

model AssistantOrder {
  id String @id @default(cuid(2))

  assistantId String    @map("assistant_id")
  assistant   Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)

  instructorId String     @map("instructor_id")
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  lectureId  String?  @map("lecture_id")
  lecture    Lecture? @relation(fields: [lectureId], references: [id], onDelete: SetNull)

  attachments OrderAttachment[]

  title    String
  memo     String?
  status   String  @default("PENDING")
  priority String  @default("NORMAL")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  deadlineAt DateTime? @map("deadline_at")

  @@index([assistantId])
  @@index([instructorId])
  @@index([lectureId])
  @@map("assistant_orders")
}

model OrderAttachment {
  id       String  @id @default(cuid(2))
  filename String
  fileUrl  String? @map("file_url")

  orderId String  @map("order_id")
  materialId       String? @map("material_id")

  createdAt DateTime @default(now()) @map("created_at")

  order    AssistantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  material Material?      @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_attachments")
}


// --------------------------------------------------------
// 8. COMMUNICATION (소통)
// --------------------------------------------------------

model InstructorPost {
  id String @id @default(cuid(2))

  scope      String @default("LECTURE") // GLOBAL, LECTURE, SELECTED
  targetRole String @default("ALL") @map("target_role") // ALL, STUDENT, PARENT

  isImportant Boolean   @default(false) @map("is_important")
  title       String
  content     String    @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  authorRole        String  @default("INSTRUCTOR") @map("author_role")
  instructorId      String  @map("instructor_id")
  lectureId         String? @map("lecture_id")
  authorAssistantId String? @map("author_assistant_id")

  instructor      Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  lecture         Lecture?   @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  authorAssistant Assistant? @relation(fields: [authorAssistantId], references: [id], onDelete: SetNull)

  targets     InstructorPostTarget[]
  attachments InstructorPostAttachment[]
  comments    Comment[]

  // [Performance] 게시글 피드 조회 (최신순)
  @@index([lectureId, createdAt(sort: Desc)])
  @@index([instructorId])
  @@map("instructor_posts")
}

model InstructorPostTarget {
  instructorPostId String @map("instructor_post_id")
  enrollmentId     String @map("enrollment_id")

  instructorPost InstructorPost @relation(fields: [instructorPostId], references: [id], onDelete: Cascade)
  enrollment     Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  // [Performance] 수신함 조회
  @@id([instructorPostId, enrollmentId])
  @@index([enrollmentId])
  @@map("instructor_post_targets")
}

model InstructorPostAttachment {
  id       String  @id @default(cuid(2))
  filename String
  fileUrl  String? @map("file_url")

  instructorPostId String  @map("instructor_post_id")
  materialId       String? @map("material_id")

  createdAt DateTime @default(now()) @map("created_at")

  instructorPost InstructorPost @relation(fields: [instructorPostId], references: [id], onDelete: Cascade)
  material       Material?      @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([instructorPostId])
  @@map("instructor_post_attachments")
}

model StudentPost {
  id        String    @id @default(cuid(2))
  status    String    @default("PENDING") // PENDING, RESOLVED
  title     String
  content   String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  enrollmentId String @map("enrollment_id")
  authorRole   String @default("STUDENT") @map("author_role")

  instructorId String  @map("instructor_id")
  lectureId    String? @map("lecture_id")

  attachments StudentPostAttachment[]

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  instructor Instructor @relation("StudentPostResolver", fields: [instructorId], references: [id], onDelete: Cascade)
  lecture    Lecture?   @relation(fields: [lectureId], references: [id], onDelete: SetNull)

  comments Comment[]

  // [Performance] 질문 리스트 필터링
  @@index([instructorId, status])
  @@index([lectureId, createdAt(sort: Desc)])
  @@map("student_posts")
}

model StudentPostAttachment {
  id       String  @id @default(cuid(2))
  filename String
  fileUrl  String? @map("file_url")

  studentPostId String @map("student_post_id")

  createdAt DateTime @default(now()) @map("created_at")

  studentPost StudentPost @relation(fields: [studentPostId], references: [id], onDelete: Cascade)

  @@index([studentPostId])
  @@map("student_post_attachments")
}

model Comment {
  id        String    @id @default(cuid(2))
  content   String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  instructorPostId String? @map("instructor_post_id")
  studentPostId    String? @map("student_post_id")

  instructorId String? @map("instructor_id")
  assistantId  String? @map("assistant_id")
  enrollmentId String? @map("enrollment_id")

  instructorPost InstructorPost? @relation(fields: [instructorPostId], references: [id], onDelete: Cascade)
  studentPost    StudentPost?    @relation(fields: [studentPostId], references: [id], onDelete: Cascade)

  instructor Instructor? @relation(fields: [instructorId], references: [id])
  assistant  Assistant?  @relation(fields: [assistantId], references: [id])
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id])

  attachments CommentAttachment[]

  @@index([instructorPostId])
  @@index([studentPostId])
  @@map("comments")
}

model CommentAttachment {
  id       String  @id @default(cuid(2))
  filename String
  fileUrl  String? @map("file_url")

  commentId  String  @map("comment_id")
  materialId String? @map("material_id")

  createdAt DateTime @default(now()) @map("created_at")

  comment  Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  material Material? @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@map("comment_attachments")
}

// --------------------------------------------------------
// 9. AUTHENTICATION (Better Auth 통합 인증 시스템)
// --------------------------------------------------------

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @map("email_verified")
  image         String?
  createdAt     DateTime @map("created_at")
  updatedAt     DateTime @map("updated_at")

  // Custom: Role-based user type for easier identification
  userType String @map("user_type") // INSTRUCTOR, ASSISTANT, STUDENT, PARENT

  sessions Session[]
  accounts Account[]

  // Profile links
  studentProfile    AppStudent?
  parentProfile     AppParent?
  instructorProfile Instructor?
  assistantProfile  Assistant?

  role       String?
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@map("session")
  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @map("updated_at")

  @@map("account")
  @@index([userId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  @@map("verification")
  @@index([identifier])
}
