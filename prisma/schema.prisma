// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------------------------
// 1. APP USERS (서비스 실사용자 - 학생/학부모)
// --------------------------------------------------------

// 사용자 권한 레이어 (아이덴티티)

model AppStudent {
  id     String @id @default(uuid(7))
  userId String @unique @map("user_id")

  phoneNumber String  @unique @map("phone_number")
  school      String?
  schoolYear  String? @map("school_year")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@map("app_students")
}

model AppParent {
  id     String @id @default(uuid(7))
  userId String @unique @map("user_id")

  phoneNumber String   @unique @map("phone_number")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  childLinks ParentChildLink[]

  @@map("app_parents")
}

model ParentChildLink {
  id          String @id @default(uuid(7))
  appParentId String @map("app_parent_id")
  name        String
  phoneNumber String @map("phone_number")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  parent     AppParent    @relation(fields: [appParentId], references: [id], onDelete: Cascade)
  enrollment Enrollment[]

  @@unique([appParentId, phoneNumber])
  @@map("parent_child_links")
}

model VerificationCode {
  id          String @id @default(uuid(7))
  targetPhone String @map("target_phone")
  code        String

  // Values: "SIGNUP", "PARENT_CHILD_CONNECT"
  type String

  isVerified Boolean  @default(false) @map("is_verified")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("verification_codes")
}

// --------------------------------------------------------
// 2. ADMIN & PROVIDERS (학원 관리자 - 강사/조교)
// --------------------------------------------------------

model Instructor {
  id     String @id @default(uuid(7))
  userId String @unique @map("user_id")

  phoneNumber String  @unique @map("phone_number")
  subject     String?
  academy     String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // 회원 탈퇴 요청 시 선 Soft Delete 후 이 날로 부터 1개월 지나면 Hard Delete 및 회원 탈퇴 처리

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lectures        Lecture[]
  lectureTimes    LectureTime[]
  enrollments     Enrollment[]
  instructorExams Exam[]
  assistants      Assistant[]
  assistantCodes  AssistantCode[]
  scheduleCategories ScheduleCategory[]
  schedules       Schedule[]
  ownedMaterials  Material[]       @relation("MaterialOwner")
  instructorPosts InstructorPost[]
  comments        Comment[]
  resolvedPosts   StudentPost[]    @relation("StudentPostResolver")

  // [Audit] 성적 수정 이력
  //updatedGradeLogs GradeLog[]
  clinics Clinic[]

  // [Assistant] 조교에 지시한 업무 요청
  assistantOrders AssistantOrder[]

  @@map("instructors")
}

model Assistant {
  id           String  @id @default(uuid(7))
  userId       String? @unique @map("user_id")
  instructorId String  @map("instructor_id")

  name        String
  phoneNumber String? @unique @map("phone_number")

  signupCode String? @map("signup_code")
  contract   String?
  memo       String?

  signStatus String @default("PENDING") @map("sign_status") // PENDING(미서명), REJECTED(거절), SIGNED(서명), EXPIRED(만료)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // 회원 탈퇴 처리 시 즉시 탈퇴 후 이 테이블은 Soft Delete, 이 날로 부터 3년 또는 강사 탈퇴 후 Hard Delete

  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  instructor    Instructor       @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  comments      Comment[]
  authoredPosts InstructorPost[]

  // [Assistant] 조교가 받은 업무 요청
  assistantOrders AssistantOrder[]

  // [Audit] 조교가 성적을 수정한 경우 기록
  //updatedGradeLogs GradeLog[]

  // [Performance] 강사별 조교 목록 조회
  @@index([instructorId])
  @@map("assistants")
}

model AssistantCode {
  id           String   @id @default(uuid(7))
  code         String   @unique
  instructorId String   @map("instructor_id")
  isUsed       Boolean  @default(false) @map("is_used")
  expireAt     DateTime @map("expire_at")
  createdAt    DateTime @default(now()) @map("created_at")

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId])
  @@map("assistant_codes")
}

// --------------------------------------------------------
// 3. ACADEMIC STRUCTURE (강의 및 수강생)
// --------------------------------------------------------

// 1. [Enrollment] 강사의 수업을 듣는 모든 학생, 

model Enrollment {
  id String @id @default(cuid(2))

  // [Relationship Definition] 누구와 누구의 관계인가?
  instructorId String     @map("instructor_id")
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  // [Link] 실제 앱 사용자와의 연결 (학생 본체)
  appStudentId    String?          @map("app_student_id")
  appStudent      AppStudent?      @relation(fields: [appStudentId], references: [id], onDelete: SetNull)
  appParentLinkId String?          @map("app_parent_link_id")
  appParentLink   ParentChildLink? @relation(fields: [appParentLinkId], references: [id], onDelete: SetNull)

  // [Snapshot & Profile] 학생 기본 정보 (강사가 관리하는 주소록 개념)
  studentName  String    @map("student_name")
  studentEmail String?   @map("student_email")
  studentPhone String    @map("student_phone") // 이 정보를 통해 동일성 및 연속성 확보
  parentPhone  String    @map("parent_phone")
  school       String
  schoolYear   String    @map("school_year")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  // [Meta] 관계 메타데이터
  registeredAt DateTime  @default(now()) @map("registered_at") // 최초 관계 맺은 날
  status       String    @default("ACTIVE") // [State] ACTIVE: 수강중, DROPPED: 퇴원, PAUSED: 휴원
  memo         String? // [Note] 학생에 대한 누적/종합 메모 (성향, 특이사항 등)
  deletedAt    DateTime? @map("deleted_at")

  // [Children] 이 관계 하에서 발생한 수강 이력들
  lectureEnrollments LectureEnrollment[]
  attendances        Attendance[]

  // [Children] 이 관계 하에서 발생한 게시글들
  studentPosts            StudentPost[]
  comments                Comment[]
  receivedInstructorPosts InstructorPostTarget[]

  // [Optimization] 강사별 학생 검색, 전화번호 검색 최적화
  @@unique([instructorId, studentPhone])
  @@index([instructorId])
  @@index([studentPhone])
  @@index([appStudentId])
  @@map("enrollments")
}

model Lecture {
  id           String @id @default(cuid(2))
  instructorId String @map("instructor_id")

  subject     String?
  schoolYear  String?
  title       String
  description String? @db.Text

  status    String    @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  startAt   DateTime? @map("start_at")
  endAt     DateTime? @map("end_at")

  // [Safety] 강의 삭제 시 연관 데이터 보존을 위한 Soft Delete
  deletedAt DateTime? @map("deleted_at")

  instructor Instructor @relation(fields: [instructorId], references: [id])

  lectureEnrollments LectureEnrollment[]
  attendances        Attendance[]
  exams              Exam[]
  materials          Material[]
  clinics            Clinic[]
  lectureTimes       LectureTime[]

  instructorPosts InstructorPost[]
  studentPosts    StudentPost[]
  assistantOrders AssistantOrder[]

  // [Performance] 강사별 강의 목록 조회
  @@index([instructorId])
  @@map("lectures")
}

model LectureTime {
  id           String @id @default(cuid(2))
  lectureId    String @map("lecture_id")
  instructorId String @map("instructor_id")

  day       String // MONDAY, TUESDAY, ...
  startTime String @map("start_time") // 14:00
  endTime   String @map("end_time") // 16:00

  lecture    Lecture    @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([lectureId])
  @@index([instructorId])
  @@map("lecture_times")
}

// 2. [LectureEnrollment] 개별 강의 단위의 '수강 명단' 테이블
// - 실제 출석부, 성적 처리, 과제 제출 등이 일어나는 단위입니다.

model LectureEnrollment {
  id   String  @id @default(cuid(2))
  memo String?

  // [Parent] 어떤 '관계(Enrollment)'에서 파생된 수강인가?
  enrollmentId String     @map("enrollment_id")
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  // [Target] 어떤 '강의(Lecture)'를 듣는가?
  lectureId String  @map("lecture_id")
  lecture   Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  // [Meta] 수강 시점 정보
  registeredAt DateTime @default(now()) @map("registered_at") // 이 수업 등록일

  // [Activities] 수업 내 활동 데이터 연결
  // 성적, 과제, 출석은 '학생 전체'가 아니라 '이 수업'에 종속되므로 여기로 이동합니다.
  grades         Grade[]
  studentAnswers StudentAnswer[]
  clinics        Clinic[]
  attendances    Attendance[]

  // 한 수업에 중복 등록 방지
  @@unique([lectureId, enrollmentId])
  @@index([enrollmentId])
  @@map("lecture_enrollments")
}

model Attendance {
  id                  String @id @default(cuid(2))
  lectureId           String @map("lecture_id")
  enrollmentId        String @map("enrollment_id")
  lectureEnrollmentId String @map("lecture_enrollment_id")

  date   DateTime @db.Date // 시간 제외한 날짜
  status String   @default("ABSENT") // PRESENT, LATE, ABSENT, EARLY_LEAVE 등

  enterTime DateTime? @map("enter_time")
  leaveTime DateTime? @map("leave_time")
  memo      String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  lecture           Lecture           @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  enrollment        Enrollment        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lectureEnrollment LectureEnrollment @relation(fields: [lectureEnrollmentId], references: [id], onDelete: Cascade)

  // [Constraint] 강사에 등록된 학생은 하루에 하나의 출석 데이터만 가짐
  // [Performance] 날짜별/상태별 조회 (예: 오늘 결석자 조회)
  @@unique([lectureId, enrollmentId, date])
  @@unique([lectureEnrollmentId, date])
  @@index([date, status])
  @@index([enrollmentId])
  @@index([lectureEnrollmentId])
  @@map("attendances")
}

// --------------------------------------------------------
// 5. EXAM & EVALUATION (평가 및 피드백 레이어)
// --------------------------------------------------------

model Exam {
  id           String  @id @default(cuid(2))
  lectureId    String  @map("lecture_id")
  instructorId String  @map("instructor_id")
  title        String
  description  String?
  subject      String?
  cutoffScore  Int     @default(0) @map("cutoff_score")
  source       String?

  averageScore Float? @map("average_score")
  gradesCount  Int    @default(0) @map("grades_count")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  gradingStatus String     @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  examDate      DateTime?  @map("exam_date") @db.Date
  category      String?
  isAutoClinic  Boolean    @default(true) @map("is_auto_clinic")
  lecture       Lecture    @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  instructor    Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  questions Question[]
  grades    Grade[]
  clinics   Clinic[]

  // [Performance] 강의 내 시험 목록 조회
  @@unique([lectureId, id])
  @@index([lectureId])
  @@map("exams")
}

model Question {
  id        String @id @default(cuid(2))
  examId    String @map("exam_id")
  lectureId String @map("lecture_id")

  questionNumber Int    @map("question_number")
  content        String @db.Text

  type     String  @default("MULTIPLE") // MULTIPLE, ESSAY
  score    Int     @default(0)
  choices  Json? // 보기 문항 (Postgres JSONB)
  source   String?
  category String?

  correctAnswer String @map("correct_answer")

  exam Exam @relation(fields: [lectureId, examId], references: [lectureId, id], onDelete: Cascade)

  studentAnswers StudentAnswer[]
  statistic      QuestionStatistic?

  // [Performance] 시험지 렌더링 시 문항 번호 순 정렬
  @@unique([lectureId, id])
  @@index([examId, questionNumber])
  @@index([lectureId])
  @@map("questions")
}

model QuestionStatistic {
  id         String @id @default(cuid(2))
  examId     String @map("exam_id")
  questionId String @unique @map("question_id")

  totalSubmissions Int      @default(0) @map("total_submissions")
  // 정답률 (0~100)
  correctRate      Float    @default(0) @map("correct_rate") // 보기별 선택 비율: { "1": 15.5, "2": 70.0, ... }
  choiceRates      Json?    @map("choice_rates")
  createdAt        DateTime @default(now()) @map("created_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@map("question_statistics")
}

model StudentAnswer {
  id                  String @id @default(cuid(2))
  lectureId           String @map("lecture_id")
  lectureEnrollmentId String @map("lecture_enrollment_id")
  questionId          String @map("question_id")

  submittedAnswer String  @map("submitted_answer")
  isCorrect       Boolean @default(false) @map("is_correct")

  createdAt DateTime @default(now()) @map("created_at")

  lectureEnrollment LectureEnrollment @relation(fields: [lectureEnrollmentId], references: [id], onDelete: Cascade)
  question          Question          @relation(fields: [lectureId, questionId], references: [lectureId, id], onDelete: Cascade)

  // [Performance] 통계 및 답안 조회 최적화
  @@unique([lectureEnrollmentId, questionId])
  @@index([questionId])
  @@index([lectureId])
  @@index([lectureEnrollmentId])
  @@map("student_answers")
}

model Grade {
  id                  String @id @default(cuid(2))
  lectureId           String @map("lecture_id")
  examId              String @map("exam_id")
  lectureEnrollmentId String @map("lecture_enrollment_id")

  score  Int
  rank   Int?
  isPass Boolean @default(true) @map("is_pass")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  exam              Exam              @relation(fields: [lectureId, examId], references: [lectureId, id], onDelete: Cascade)
  lectureEnrollment LectureEnrollment @relation(fields: [lectureEnrollmentId], references: [id], onDelete: Cascade)

  //logs GradeLog[]

  // [Performance] 석차 계산 및 성적 조회
  @@unique([examId, lectureEnrollmentId])
  @@index([examId, score(sort: Desc)])
  @@index([lectureEnrollmentId])
  @@map("grades")
}

