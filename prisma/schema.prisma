// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------------------------
// 1. APP USERS (서비스 실사용자 - 학생/학부모)
// --------------------------------------------------------

// 사용자 권한 레이어 (아이덴티티)

model AppStudent {
  id     String @id @default(uuid(7))
  userId String @unique @map("user_id")

  phoneNumber       String  @unique @map("phone_number")
  parentPhoneNumber String? @map("parent_phone_number")
  school            String?
  schoolYear        String? @map("school_year")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@map("app_students")
}

model AppParent {
  id     String @id @default(uuid(7))
  userId String @unique @map("user_id")

  phoneNumber String   @unique @map("phone_number")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  childLinks ParentChildLink[]

  @@map("app_parents")
}

model ParentChildLink {
  id          String @id @default(uuid(7))
  appParentId String @map("app_parent_id")
  name        String
  phoneNumber String @map("phone_number")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  parent     AppParent    @relation(fields: [appParentId], references: [id], onDelete: Cascade)
  enrollment Enrollment[]

  @@unique([appParentId, phoneNumber])
  @@map("parent_child_links")
}

model VerificationCode {
  id          String @id @default(uuid(7))
  targetPhone String @map("target_phone")
  code        String

  // Values: "SIGNUP", "PARENT_CHILD_CONNECT"
  type String

  isVerified Boolean  @default(false) @map("is_verified")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("verification_codes")
}

// --------------------------------------------------------
// 2. ADMIN & PROVIDERS (학원 관리자 - 강사/조교)
// --------------------------------------------------------

model Instructor {
  id     String @id @default(uuid(7))
  userId String @unique @map("user_id")

  phoneNumber String  @unique @map("phone_number")
  subject     String?
  academy     String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // 회원 탈퇴 요청 시 선 Soft Delete 후 이 날로 부터 1개월 지나면 Hard Delete 및 회원 탈퇴 처리

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lectures        Lecture[]
  lectureTimes    LectureTime[]
  enrollments     Enrollment[]
  instructorExams Exam[]
  assistants      Assistant[]
  assistantCodes  AssistantCode[]
  scheduleCategories ScheduleCategory[]
  schedules       Schedule[]
  ownedMaterials  Material[]       @relation("MaterialOwner")
  instructorPosts InstructorPost[]
  comments        Comment[]
  resolvedPosts   StudentPost[]    @relation("StudentPostResolver")
  assignments     Assignment[]
  assignmentCategories AssignmentCategory[]

  // [Audit] 성적 수정 이력
  //updatedGradeLogs GradeLog[]
  clinics Clinic[]

  // [Assistant] 조교에 지시한 업무 요청
  assistantOrders AssistantOrder[]

  // [Billing] 결제/이용권/크레딧
  payments      Payment[]
  entitlements  Entitlement[]
  creditWallet  CreditWallet?
  creditBuckets CreditBucket[]
  creditLedgers CreditLedger[]

  @@map("instructors")
}

model Assistant {
  id           String  @id @default(uuid(7))
  userId       String? @unique @map("user_id")
  instructorId String  @map("instructor_id")

  name        String
  phoneNumber String? @unique @map("phone_number")

  signupCode String? @map("signup_code")
  contract   String?
  memo       String?

  signStatus String @default("PENDING") @map("sign_status") // PENDING(미서명), REJECTED(거절), SIGNED(서명), EXPIRED(만료)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // 회원 탈퇴 처리 시 즉시 탈퇴 후 이 테이블은 Soft Delete, 이 날로 부터 3년 또는 강사 탈퇴 후 Hard Delete

  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  instructor    Instructor       @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  comments      Comment[]
  authoredPosts InstructorPost[]

  // [Assistant] 조교가 받은 업무 요청
  assistantOrders AssistantOrder[]

  // [Audit] 조교가 성적을 수정한 경우 기록
  //updatedGradeLogs GradeLog[]

  // [Performance] 강사별 조교 목록 조회
  @@index([instructorId])
  @@map("assistants")
}

model AssistantCode {
  id           String   @id @default(uuid(7))
  code         String   @unique
  instructorId String   @map("instructor_id")
  isUsed       Boolean  @default(false) @map("is_used")
  expireAt     DateTime @map("expire_at")
  createdAt    DateTime @default(now()) @map("created_at")

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId])
  @@map("assistant_codes")
}

model Admin {
  id String @id @default(uuid(7))

  userId String @unique @map("user_id")
  status String @default("PENDING_ACTIVATION")

  isPrimaryAdmin Boolean  @default(false) @map("is_primary_admin")
  invitedByUserId String? @map("invited_by_user_id")
  invitedAt DateTime?     @map("invited_at")
  activatedAt DateTime?   @map("activated_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([invitedByUserId])
  @@map("admins")
}

// --------------------------------------------------------
// 3. ACADEMIC STRUCTURE (강의 및 수강생)
// --------------------------------------------------------

// 1. [Enrollment] 강사의 수업을 듣는 모든 학생, 

model Enrollment {
  id String @id @default(cuid(2))

  // [Relationship Definition] 누구와 누구의 관계인가?
  instructorId String     @map("instructor_id")
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  // [Link] 실제 앱 사용자와의 연결 (학생 본체)
  appStudentId    String?          @map("app_student_id")
  appStudent      AppStudent?      @relation(fields: [appStudentId], references: [id], onDelete: SetNull)
  appParentLinkId String?          @map("app_parent_link_id")
  appParentLink   ParentChildLink? @relation(fields: [appParentLinkId], references: [id], onDelete: SetNull)

  // [Snapshot & Profile] 학생 기본 정보 (강사가 관리하는 주소록 개념)
  studentName  String    @map("student_name")
  studentEmail String?   @map("student_email")
  studentPhone String    @map("student_phone") // 이 정보를 통해 동일성 및 연속성 확보
  parentPhone  String    @map("parent_phone")
  school       String
  schoolYear   String    @map("school_year")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  // [Meta] 관계 메타데이터
  registeredAt DateTime  @default(now()) @map("registered_at") // 최초 관계 맺은 날
  status       String    @default("ACTIVE") // [State] ACTIVE: 수강중, DROPPED: 퇴원, PAUSED: 휴원
  memo         String? // [Note] 학생에 대한 누적/종합 메모 (성향, 특이사항 등)
  deletedAt    DateTime? @map("deleted_at")

  // [Children] 이 관계 하에서 발생한 수강 이력들
  lectureEnrollments LectureEnrollment[]
  attendances        Attendance[]

  // [Children] 이 관계 하에서 발생한 게시글들
  studentPosts            StudentPost[]
  comments                Comment[]
  receivedInstructorPosts InstructorPostTarget[]

  // [Optimization] 강사별 학생 검색, 전화번호 검색 최적화
  @@unique([instructorId, studentPhone])
  @@index([instructorId])
  @@index([studentPhone])
  @@index([appStudentId])
  @@map("enrollments")
}

model Lecture {
  id           String @id @default(cuid(2))
  instructorId String @map("instructor_id")

  subject     String?
  schoolYear  String?
  title       String
  description String? @db.Text

  status    String    @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  startAt   DateTime? @map("start_at")
  endAt     DateTime? @map("end_at")

  // [Safety] 강의 삭제 시 연관 데이터 보존을 위한 Soft Delete
  deletedAt DateTime? @map("deleted_at")

  instructor Instructor @relation(fields: [instructorId], references: [id])

  lectureEnrollments LectureEnrollment[]
  attendances        Attendance[]
  exams              Exam[]
  materials          Material[]
  clinics            Clinic[]
  lectureTimes       LectureTime[]

  assignments Assignment[]

  instructorPosts InstructorPost[]
  studentPosts    StudentPost[]
  assistantOrders AssistantOrder[]

  // [Performance] 강사별 강의 목록 조회
  @@index([instructorId])
  @@map("lectures")
}

model LectureTime {
  id           String @id @default(cuid(2))
  lectureId    String @map("lecture_id")
  instructorId String @map("instructor_id")

  day       String // MONDAY, TUESDAY, ...
  startTime String @map("start_time") // 14:00
  endTime   String @map("end_time") // 16:00

  lecture    Lecture    @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([lectureId])
  @@index([instructorId])
  @@map("lecture_times")
}

// 2. [LectureEnrollment] 개별 강의 단위의 '수강 명단' 테이블
// - 실제 출석부, 성적 처리, 과제 제출 등이 일어나는 단위입니다.

model LectureEnrollment {
  id   String  @id @default(cuid(2))
  memo String?

  // [Parent] 어떤 '관계(Enrollment)'에서 파생된 수강인가?
  enrollmentId String     @map("enrollment_id")
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  // [Target] 어떤 '강의(Lecture)'를 듣는가?
  lectureId String  @map("lecture_id")
  lecture   Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  // [Meta] 수강 시점 정보
  registeredAt DateTime @default(now()) @map("registered_at") // 이 수업 등록일

  // [Activities] 수업 내 활동 데이터 연결
  // 성적, 과제, 출석은 '학생 전체'가 아니라 '이 수업'에 종속되므로 여기로 이동합니다.
  grades         Grade[]
  studentAnswers StudentAnswer[]
  clinics        Clinic[]
  attendances    Attendance[]
  gradeReports   GradeReport[]
  assignmentResults AssignmentResult[]

  // 한 수업에 중복 등록 방지
  @@unique([lectureId, enrollmentId])
  @@index([enrollmentId])
  @@map("lecture_enrollments")
}

model Attendance {
  id                  String @id @default(cuid(2))
  lectureId           String @map("lecture_id")
  enrollmentId        String @map("enrollment_id")
  lectureEnrollmentId String @map("lecture_enrollment_id")

  date   DateTime @db.Date // 시간 제외한 날짜
  status String   @default("ABSENT") // PRESENT, LATE, ABSENT, EARLY_LEAVE 등

  enterTime DateTime? @map("enter_time")
  leaveTime DateTime? @map("leave_time")
  memo      String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  lecture           Lecture           @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  enrollment        Enrollment        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lectureEnrollment LectureEnrollment @relation(fields: [lectureEnrollmentId], references: [id], onDelete: Cascade)

  // [Constraint] 강사에 등록된 학생은 하루에 하나의 출석 데이터만 가짐
  // [Performance] 날짜별/상태별 조회 (예: 오늘 결석자 조회)
  @@unique([lectureId, enrollmentId, date])
  @@unique([lectureEnrollmentId, date])
  @@index([date, status])
  @@index([enrollmentId])
  @@index([lectureEnrollmentId])
  @@map("attendances")
}

// --------------------------------------------------------
// 5. EXAM & EVALUATION (평가 및 피드백 레이어)
// --------------------------------------------------------

// 1. 과제 카테고리 (강사별 커스텀 평가 척도)
model AssignmentCategory {
  id           String   @id @default(cuid(2))
  instructorId String   @map("instructor_id") // 강사 참조
  name         String   // 예: "주간 단어 테스트", "독후감 과제"
  
  // 프리셋 예시: ["미흡", "보통", "우수"] -> 인덱스 0, 1, 2와 매칭
  resultPresets String[] @map("result_presets")
  
  assignments  Assignment[]
  createdAt    DateTime @default(now()) @map("created_at")

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, name])
  @@index([instructorId])
  @@map("assignment_categories")
}

// 2. 과제 (특정 강의 내에서 생성된 과제)
model Assignment {
  id           String   @id @default(cuid(2))
  instructorId String   @map("instructor_id")
  lectureId   String   @map("lecture_id")
  categoryId  String   @map("category_id")
  title       String   // 과제 이름 (예: 2/12 단어시험)
  
  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  category    AssignmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  assignmentResults AssignmentResult[]
  assignmentsOnExamReport AssignmentOnExamReport[]

  @@index([lectureId])
  @@index([categoryId])
  @@map("assignments")
}

// 3. 학생 과제 (학생별 결과)
model AssignmentResult {
  id           String   @id @default(cuid(2))
  assignmentId String   @map("assignment_id")
  lectureEnrollmentId String @map("lecture_enrollment_id")

  resultIndex  Int  @map("result_index")
  
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  lectureEnrollment LectureEnrollment @relation(fields: [lectureEnrollmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, lectureEnrollmentId]) // 한 학생이 한 과제에 중복 점수 방지
  @@index([assignmentId])
  @@index([lectureEnrollmentId])
  @@map("assignment_results")
}

model AssignmentOnExamReport {
  id           String   @id @default(cuid(2))
  assignmentId String   @map("assignment_id")
  examId       String   @map("exam_id")
  
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, examId]) // 한 과제가 한 시험에 중복 등록 방지
  @@index([assignmentId])
  @@index([examId])
  @@map("assignment_on_exam_reports")
}

// 4. 시험 (특정 강의 내에서 생성된 시험)

model Exam {
  id           String  @id @default(cuid(2))
  lectureId    String  @map("lecture_id")
  instructorId String  @map("instructor_id")
  title        String
  description  String? @db.Text
  subject      String?
  cutoffScore  Int     @default(0) @map("cutoff_score")
  source       String?

  averageScore Float? @map("average_score")
  gradesCount  Int    @default(0) @map("grades_count")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  gradingStatus String     @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  examDate      DateTime?  @map("exam_date") @db.Date
  category      String?
  isAutoClinic  Boolean    @default(true) @map("is_auto_clinic")
  lecture       Lecture    @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  instructor    Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  questions Question[]
  grades    Grade[]
  clinics   Clinic[]
  gradeReports GradeReport[]
  assignmentsOnExamReport AssignmentOnExamReport[]

  // [Performance] 강의 내 시험 목록 조회
  @@unique([lectureId, id])
  @@index([lectureId])
  @@map("exams")
}

model Question {
  id        String @id @default(cuid(2))
  examId    String @map("exam_id")
  lectureId String @map("lecture_id")

  questionNumber Int    @map("question_number")
  content        String @db.Text

  type     String  @default("MULTIPLE") // MULTIPLE, ESSAY
  score    Int     @default(0)
  choices  Json? // 보기 문항 (Postgres JSONB)
  source   String?
  category String?

  correctAnswer String @map("correct_answer")

  exam Exam @relation(fields: [lectureId, examId], references: [lectureId, id], onDelete: Cascade)

  studentAnswers StudentAnswer[]
  statistic      QuestionStatistic?

  // [Performance] 시험지 렌더링 시 문항 번호 순 정렬
  @@unique([lectureId, id])
  @@index([examId, questionNumber])
  @@index([lectureId])
  @@map("questions")
}

model QuestionStatistic {
  id         String @id @default(cuid(2))
  examId     String @map("exam_id")
  questionId String @unique @map("question_id")

  totalSubmissions Int      @default(0) @map("total_submissions")
  // 정답률 (0~100)
  correctRate      Float    @default(0) @map("correct_rate") // 보기별 선택 비율: { "1": 15.5, "2": 70.0, ... }
  choiceRates      Json?    @map("choice_rates")
  createdAt        DateTime @default(now()) @map("created_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@map("question_statistics")
}

model StudentAnswer {
  id                  String @id @default(cuid(2))
  lectureId           String @map("lecture_id")
  lectureEnrollmentId String @map("lecture_enrollment_id")
  questionId          String @map("question_id")

  submittedAnswer String  @map("submitted_answer")
  isCorrect       Boolean @default(false) @map("is_correct")

  createdAt DateTime @default(now()) @map("created_at")

  lectureEnrollment LectureEnrollment @relation(fields: [lectureEnrollmentId], references: [id], onDelete: Cascade)
  question          Question          @relation(fields: [lectureId, questionId], references: [lectureId, id], onDelete: Cascade)

  // [Performance] 통계 및 답안 조회 최적화
  @@unique([lectureEnrollmentId, questionId])
  @@index([questionId])
  @@index([lectureId])
  @@index([lectureEnrollmentId])
  @@map("student_answers")
}

model Grade {
  id                  String @id @default(cuid(2))
  lectureId           String @map("lecture_id")
  examId              String @map("exam_id")
  lectureEnrollmentId String @map("lecture_enrollment_id")

  score  Int
  rank   Int?
  isPass Boolean @default(true) @map("is_pass")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  exam              Exam              @relation(fields: [lectureId, examId], references: [lectureId, id], onDelete: Cascade)
  lectureEnrollment LectureEnrollment @relation(fields: [lectureEnrollmentId], references: [id], onDelete: Cascade)

  gradeReports GradeReport[]
  //logs GradeLog[]

  // [Performance] 석차 계산 및 성적 조회
  @@unique([examId, lectureEnrollmentId])
  @@index([examId, score(sort: Desc)])
  @@index([lectureEnrollmentId])
  @@map("grades")
}

model GradeReport {
  id                  String @id @default(cuid(2))
  examId              String @map("exam_id")
  gradeId             String @unique @map("grade_id")
  lectureEnrollmentId String @map("lecture_enrollment_id")

  description String  @db.Text
  reportUrl   String? @map("report_url")

  sentAt    DateTime? @map("sent_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  exam              Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  grade             Grade             @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  lectureEnrollment LectureEnrollment @relation(fields: [lectureEnrollmentId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([gradeId])
  @@index([lectureEnrollmentId])
  @@map("grade_reports")
}

// --------------------------------------------------------
// 6. CLINIC (클리닉/재시험 관리)
// --------------------------------------------------------

model Clinic {
  id        String @id @default(cuid(2))
  lectureId String @map("lecture_id")
  examId    String @map("exam_id")

  // 기존 Clinic 필드
  title     String
  deadline  DateTime?

  // 기존 ClinicTarget 필드 통합
  lectureEnrollmentId String  @map("lecture_enrollment_id")
  status              String  @default("PENDING") // PENDING, SENT, COMPLETED
  memo                String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  // 관계 설정
  lecture           Lecture           @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  exam              Exam              @relation(fields: [lectureId, examId], references: [lectureId, id], onDelete: Cascade)
  lectureEnrollment LectureEnrollment @relation(fields: [lectureEnrollmentId], references: [id], onDelete: Cascade)

  instructorId String?     @map("instructor_id")
  instructor   Instructor? @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  // 인덱스 및 제약 조건
  // 한 수강생이 동일한 시험에 대해 중복 클리닉을 받지 않도록 유니크 설정 (필요시)
  @@unique([lectureEnrollmentId, examId])
  @@index([examId])
  @@index([lectureEnrollmentId])
  @@index([status])
  @@map("clinics")
}

// --------------------------------------------------------
// 7. OPERATION SUPPORT (운영 지원)
// --------------------------------------------------------

model ScheduleCategory {
  id           String   @id @default(cuid(2))
  instructorId String   @map("instructor_id")

  name String
  color String

  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  schedules    Schedule[]

  @@unique([instructorId, name])
  @@unique([instructorId, color])
  @@index([instructorId])
  @@map("schedule_categories")
}

model Schedule {
  id           String   @id @default(cuid(2))
  instructorId String   @map("instructor_id")

  authorName String @map("author_name")
  authorRole String @map("author_role")

  title        String
  memo         String? @db.Text
  startTime    DateTime @map("start_time")
  endTime      DateTime @map("end_time")

  categoryId   String?   @map("category_id")
  category     ScheduleCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId, startTime])
  @@map("schedules")
}

model Material {
  id           String  @id @default(cuid(2))
  instructorId String  @map("instructor_id")
  lectureId    String? @map("lecture_id")

  authorName String @map("author_name")
  authorRole String @map("author_role")

  title    String
  filename String @default("") @map("filename")
  fileUrl  String @map("file_url")
  type    String @default("OTHER") // PAPER, VIDEO, REQUEST, OTHER

  // New fields
  description         String? @db.Text // 소개/세부 내용
  subject             String? // 과목
  externalDownloadUrl String? @map("external_download_url") // 외부 다운로드 링크

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  lecture    Lecture?   @relation(fields: [lectureId], references: [id], onDelete: SetNull)
  instructor Instructor @relation("MaterialOwner", fields: [instructorId], references: [id], onDelete: Cascade)

  instructorPostAttachments InstructorPostAttachment[]
  commentAttachments        CommentAttachment[]
  orderAttachments          OrderAttachment[]

  @@index([instructorId])
  @@index([lectureId])
  @@index([deletedAt])
  @@map("materials")
}

model AssistantOrder {
  id String @id @default(cuid(2))

  assistantId String    @map("assistant_id")
  assistant   Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)

  instructorId String     @map("instructor_id")
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  lectureId  String?  @map("lecture_id")
  lecture    Lecture? @relation(fields: [lectureId], references: [id], onDelete: SetNull)

  attachments OrderAttachment[]

  title    String
  memo     String?
  status   String  @default("PENDING")
  priority String  @default("NORMAL")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  deadlineAt DateTime? @map("deadline_at")

  @@index([assistantId])
  @@index([instructorId])
  @@index([lectureId])
  @@map("assistant_orders")
}

model OrderAttachment {
  id       String  @id @default(cuid(2))
  filename String
  fileUrl  String? @map("file_url")

  orderId String  @map("order_id")
  materialId       String? @map("material_id")

  createdAt DateTime @default(now()) @map("created_at")

  order    AssistantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  material Material?      @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_attachments")
}


// --------------------------------------------------------
// 8. COMMUNICATION (소통)
// --------------------------------------------------------

model InstructorPost {
  id String @id @default(cuid(2))

  scope      String @default("LECTURE") // GLOBAL, LECTURE, SELECTED
  targetRole String @default("ALL") @map("target_role") // ALL, STUDENT, PARENT

  isImportant Boolean   @default(false) @map("is_important")
  title       String
  content     String    @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  authorRole        String  @default("INSTRUCTOR") @map("author_role")
  instructorId      String  @map("instructor_id")
  lectureId         String? @map("lecture_id")
  authorAssistantId String? @map("author_assistant_id")

  instructor      Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  lecture         Lecture?   @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  authorAssistant Assistant? @relation(fields: [authorAssistantId], references: [id], onDelete: SetNull)

  targets     InstructorPostTarget[]
  attachments InstructorPostAttachment[]
  comments    Comment[]

  // [Performance] 게시글 피드 조회 (최신순)
  @@index([lectureId, createdAt(sort: Desc)])
  @@index([instructorId])
  @@map("instructor_posts")
}

model InstructorPostTarget {
  instructorPostId String @map("instructor_post_id")
  enrollmentId     String @map("enrollment_id")

  instructorPost InstructorPost @relation(fields: [instructorPostId], references: [id], onDelete: Cascade)
  enrollment     Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  // [Performance] 수신함 조회
  @@id([instructorPostId, enrollmentId])
  @@index([enrollmentId])
  @@map("instructor_post_targets")
}

model InstructorPostAttachment {
  id       String  @id @default(cuid(2))
  filename String
  fileUrl  String? @map("file_url")

  instructorPostId String  @map("instructor_post_id")
  materialId       String? @map("material_id")

  createdAt DateTime @default(now()) @map("created_at")

  instructorPost InstructorPost @relation(fields: [instructorPostId], references: [id], onDelete: Cascade)
  material       Material?      @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([instructorPostId])
  @@map("instructor_post_attachments")
}

model StudentPost {
  id        String    @id @default(cuid(2))
  status    String    @default("PENDING") // PENDING, RESOLVED
  title     String
  content   String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  enrollmentId String @map("enrollment_id")
  authorRole   String @default("STUDENT") @map("author_role")

  instructorId String  @map("instructor_id")
  lectureId    String? @map("lecture_id")

  attachments StudentPostAttachment[]

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  instructor Instructor @relation("StudentPostResolver", fields: [instructorId], references: [id], onDelete: Cascade)
  lecture    Lecture?   @relation(fields: [lectureId], references: [id], onDelete: SetNull)

  comments Comment[]

  // [Performance] 질문 리스트 필터링
  @@index([instructorId, status])
  @@index([lectureId, createdAt(sort: Desc)])
  @@map("student_posts")
}

model StudentPostAttachment {
  id       String  @id @default(cuid(2))
  filename String
  fileUrl  String? @map("file_url")

  studentPostId String @map("student_post_id")

  createdAt DateTime @default(now()) @map("created_at")

  studentPost StudentPost @relation(fields: [studentPostId], references: [id], onDelete: Cascade)

  @@index([studentPostId])
  @@map("student_post_attachments")
}

model Comment {
  id        String    @id @default(cuid(2))
  content   String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  instructorPostId String? @map("instructor_post_id")
  studentPostId    String? @map("student_post_id")

  instructorId String? @map("instructor_id")
  assistantId  String? @map("assistant_id")
  enrollmentId String? @map("enrollment_id")
  authorRole   String? @default("STUDENT") @map("author_role")

  instructorPost InstructorPost? @relation(fields: [instructorPostId], references: [id], onDelete: Cascade)
  studentPost    StudentPost?    @relation(fields: [studentPostId], references: [id], onDelete: Cascade)

  instructor Instructor? @relation(fields: [instructorId], references: [id])
  assistant  Assistant?  @relation(fields: [assistantId], references: [id])
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id])

  attachments CommentAttachment[]

  @@index([instructorPostId])
  @@index([studentPostId])
  @@map("comments")
}

model CommentAttachment {
  id       String  @id @default(cuid(2))
  filename String
  fileUrl  String? @map("file_url")

  commentId  String  @map("comment_id")
  materialId String? @map("material_id")

  createdAt DateTime @default(now()) @map("created_at")

  comment  Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  material Material? @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@map("comment_attachments")
}

// --------------------------------------------------------
// 9. BILLING (결제/이용권/크레딧)
// --------------------------------------------------------

model BillingProduct {
  id                   String   @id @default(cuid(2))
  code                 String   @unique
  name                 String
  description          String?  @db.Text
  highlights           String[] @default([])
  productType          String   @map("product_type")
  billingMode          String   @default("ONE_TIME") @map("billing_mode")
  paymentMethodType    String   @map("payment_method_type")
  durationMonths       Int?     @map("duration_months")
  includedCreditAmount Int      @default(0) @map("included_credit_amount")
  rechargeCreditAmount Int      @default(0) @map("recharge_credit_amount")
  price                Int
  isActive             Boolean  @default(true) @map("is_active")
  sortOrder            Int      @default(0) @map("sort_order")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime? @updatedAt @map("updated_at")

  paymentItems PaymentItem[]

  @@index([productType, isActive])
  @@map("billing_products")
}

model Payment {
  id                String   @id @default(cuid(2))
  instructorId      String   @map("instructor_id")
  methodType        String   @map("method_type")
  providerType      String   @default("MANUAL") @map("provider_type")
  providerReference String?  @map("provider_reference")
  status            String   @default("PENDING_DEPOSIT")
  refundStatus      String   @default("NONE") @map("refund_status")
  refundMemo        String?  @map("refund_memo")
  refundCompletedAt DateTime? @map("refund_completed_at")
  depositorName     String?  @map("depositor_name")
  totalAmount       Int      @map("total_amount")
  depositedAt       DateTime? @map("deposited_at")
  approvedAt        DateTime? @map("approved_at")
  rejectedAt        DateTime? @map("rejected_at")
  canceledAt        DateTime? @map("canceled_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")

  instructor     Instructor              @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  items          PaymentItem[]
  statusHistory  PaymentStatusHistory[]
  revocationHistories PaymentItemRevocationHistory[]
  receiptRequest PaymentReceiptRequest?

  @@index([instructorId, createdAt])
  @@index([status, createdAt])
  @@map("payments")
}

model PaymentItem {
  id                           String  @id @default(cuid(2))
  paymentId                    String  @map("payment_id")
  billingProductId             String  @map("billing_product_id")
  productCodeSnapshot          String  @map("product_code_snapshot")
  productNameSnapshot          String  @map("product_name_snapshot")
  productTypeSnapshot          String  @map("product_type_snapshot")
  quantity                     Int
  unitPrice                    Int     @map("unit_price")
  totalPrice                   Int     @map("total_price")
  durationMonthsSnapshot       Int?    @map("duration_months_snapshot")
  includedCreditAmountSnapshot Int     @default(0) @map("included_credit_amount_snapshot")
  rechargeCreditAmountSnapshot Int     @default(0) @map("recharge_credit_amount_snapshot")
  rechargeExpiresInDaysSnapshot Int?   @map("recharge_expires_in_days_snapshot")

  payment        Payment        @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  billingProduct BillingProduct @relation(fields: [billingProductId], references: [id])
  entitlements   Entitlement[]
  creditBuckets  CreditBucket[]
  revocationHistories PaymentItemRevocationHistory[]

  @@index([paymentId])
  @@index([billingProductId])
  @@map("payment_items")
}

model PaymentStatusHistory {
  id          String   @id @default(cuid(2))
  paymentId   String   @map("payment_id")
  fromStatus  String?  @map("from_status")
  toStatus    String   @map("to_status")
  actorUserId String?  @map("actor_user_id")
  actorRole   String?  @map("actor_role")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@map("payment_status_histories")
}

model PaymentReceiptRequest {
  id                         String   @id @default(cuid(2))
  paymentId                  String   @unique @map("payment_id")
  type                       String
  status                     String   @default("REQUESTED")
  cashReceiptPhoneNumber     String?  @map("cash_receipt_phone_number")
  businessRegistrationNumber String?  @map("business_registration_number")
  businessName               String?  @map("business_name")
  representativeName         String?  @map("representative_name")
  taxInvoiceEmail            String?  @map("tax_invoice_email")
  businessType               String?  @map("business_type")
  businessCategory           String?  @map("business_category")
  businessAddress            String?  @map("business_address")
  requestedAt                DateTime @default(now()) @map("requested_at")
  reviewedAt                 DateTime? @map("reviewed_at")
  reviewMemo                 String?  @map("review_memo")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([type, status])
  @@map("payment_receipt_requests")
}

model Entitlement {
  id                   String   @id @default(cuid(2))
  instructorId         String   @map("instructor_id")
  paymentItemId        String   @map("payment_item_id")
  sequenceNo           Int      @map("sequence_no")
  status               String   @default("QUEUED")
  startsAt             DateTime @map("starts_at")
  endsAt               DateTime @map("ends_at")
  activatedAt          DateTime? @map("activated_at")
  expiredAt            DateTime? @map("expired_at")
  canceledAt           DateTime? @map("canceled_at")
  includedCreditAmount Int      @default(1000) @map("included_credit_amount")

  instructor   Instructor    @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  paymentItem   PaymentItem   @relation(fields: [paymentItemId], references: [id], onDelete: Cascade)
  creditBuckets CreditBucket[]

  @@unique([paymentItemId, sequenceNo])
  @@index([instructorId, status, endsAt])
  @@map("entitlements")
}

model CreditWallet {
  id                String   @id @default(cuid(2))
  instructorId      String   @unique @map("instructor_id")
  totalAvailable    Int      @default(0) @map("total_available")
  includedAvailable Int      @default(0) @map("included_available")
  rechargeAvailable Int      @default(0) @map("recharge_available")
  lastReconciledAt  DateTime? @map("last_reconciled_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@map("credit_wallets")
}

model CreditBucket {
  id              String   @id @default(cuid(2))
  instructorId    String   @map("instructor_id")
  paymentItemId   String?  @map("payment_item_id")
  entitlementId   String?  @map("entitlement_id")
  sourceType      String   @map("source_type")
  status          String   @default("ACTIVE")
  originalAmount  Int      @map("original_amount")
  remainingAmount Int      @map("remaining_amount")
  grantedAt       DateTime @default(now()) @map("granted_at")
  expiresAt       DateTime @map("expires_at")

  instructor  Instructor   @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  paymentItem  PaymentItem? @relation(fields: [paymentItemId], references: [id], onDelete: SetNull)
  entitlement  Entitlement? @relation(fields: [entitlementId], references: [id], onDelete: SetNull)
  ledgers      CreditLedger[]

  @@index([instructorId, status, expiresAt])
  @@unique([paymentItemId, sourceType])
  @@unique([entitlementId, sourceType])
  @@map("credit_buckets")
}

model CreditLedger {
  id                   String   @id @default(cuid(2))
  instructorId         String   @map("instructor_id")
  creditBucketId       String?  @map("credit_bucket_id")
  type                 String
  deltaAmount          Int      @map("delta_amount")
  balanceAfterTotal    Int      @map("balance_after_total")
  balanceAfterIncluded Int      @map("balance_after_included")
  balanceAfterRecharge Int      @map("balance_after_recharge")
  referenceType        String?  @map("reference_type")
  referenceId          String?  @map("reference_id")
  reason               String?
  createdAt            DateTime @default(now()) @map("created_at")

  instructor   Instructor   @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  creditBucket CreditBucket? @relation(fields: [creditBucketId], references: [id], onDelete: SetNull)

  @@index([instructorId, createdAt])
  @@map("credit_ledgers")
}

model PaymentItemRevocationHistory {
  id          String   @id @default(cuid(2))
  paymentId    String   @map("payment_id")
  paymentItemId String   @map("payment_item_id")
  targetType   String   @map("target_type")
  targetId     String   @map("target_id")
  actionType   String   @map("action_type")
  fromStatus   String?  @map("from_status")
  toStatus     String?  @map("to_status")
  deltaAmount  Int      @default(0) @map("delta_amount")
  actorUserId  String?  @map("actor_user_id")
  actorRole    String?  @map("actor_role")
  reason       String
  batchId      String   @map("batch_id")
  createdAt    DateTime @default(now()) @map("created_at")

  payment     Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  paymentItem PaymentItem @relation(fields: [paymentItemId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([paymentItemId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([batchId, createdAt])
  @@map("payment_item_revocation_histories")
}

// --------------------------------------------------------
// 9. AUTHENTICATION (Better Auth 통합 인증 시스템)
// --------------------------------------------------------

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @map("email_verified")
  image         String?
  createdAt     DateTime @map("created_at")
  updatedAt     DateTime @map("updated_at")

  // Custom: Role-based user type for easier identification
  userType String @map("user_type") // INSTRUCTOR, ASSISTANT, STUDENT, PARENT, ADMIN

  sessions Session[]
  accounts Account[]

  // Profile links
  studentProfile    AppStudent?
  parentProfile     AppParent?
  instructorProfile Instructor?
  assistantProfile  Assistant?
  adminProfile      Admin?

  role       String?
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@map("session")
  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @map("updated_at")

  @@map("account")
  @@index([userId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  @@map("verification")
  @@index([identifier])
}
